{
  "name": "movi-player-desktop",
  "productName": "MoviPlayer",
  "version": "0.3.1",
  "description": "MoviPlayer desktop app — play MKV, HEVC, AV1, 4K HDR locally on Windows, macOS and Linux. WebCodecs + FFmpeg WASM, no transcoding server.",
  "author": "MoviPlayer",
  "license": "Apache-2.0",
  "main": "src/main.js",
  "scripts": {
    "prestart": "node scripts/sync-assets.mjs",
    "start": "node scripts/run-electron.mjs",
    "smoke": "node scripts/run-electron.mjs scripts/smoke.js",
    "predist": "node scripts/sync-assets.mjs",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "sync": "node scripts/sync-assets.mjs"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  }
}
